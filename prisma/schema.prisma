// VitaFit Club — canonical data model
// Prisma schema mirroring the Firestore collections used by the app.
// Use this as the source of truth if/when migrating to a relational DB
// (Postgres / Lovable Cloud / Supabase). Field names match the Firestore
// document shape so frontend converters need minimal changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────
enum UserRole       { admin manager staff viewer }
enum MemberTier     { Basic Silver Gold Platinum }
enum MemberStatus   { active inactive expired suspended }
enum BookingStatus  { scheduled completed cancelled no_show }
enum PaymentStatus  { paid pending refunded failed }
enum PaymentMethod  { cash card esewa khalti stripe bank_transfer other }
enum ReminderStatus { sent queued failed }
enum ReminderChannel{ mailto smtp resend manual }

// ─────────────────────────────────────────────────────────────
//  AUTH / USERS  (Firestore: appUsers)
// ─────────────────────────────────────────────────────────────
model AppUser {
  id                  String   @id @default(cuid())
  uid                 String?  @unique               // Firebase Auth UID
  username            String   @unique
  email               String   @unique
  fullName            String
  phone               String?
  address             String?
  role                UserRole @default(staff)
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  auditLogs           AuditLog[] @relation("AuditActor")
  remindersSent       EmailReminder[]
}

// ─────────────────────────────────────────────────────────────
//  MEMBERS  (Firestore: members)
// ─────────────────────────────────────────────────────────────
model Member {
  id              String       @id @default(cuid())
  memberCode      String       @unique               // e.g. VFC-0001
  fullName        String
  email           String?
  phone           String
  address         String?
  dateOfBirth     DateTime?
  gender          String?
  tier            MemberTier   @default(Basic)
  status          MemberStatus @default(active)
  joinDate        DateTime     @default(now())
  expiryDate      DateTime?
  planId          String?
  preferences     Json?                               // dietary, training goals, notes
  emergencyContact Json?
  photoUrl        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  plan            MembershipPlan? @relation(fields: [planId], references: [id])
  bookings        Booking[]
  payments        Payment[]
  checkIns        CheckIn[]
  reminders       EmailReminder[]

  @@index([status])
  @@index([tier])
  @@index([expiryDate])
}

// ─────────────────────────────────────────────────────────────
//  PLANS & SERVICES  (Firestore: membershipPlans, services)
// ─────────────────────────────────────────────────────────────
model MembershipPlan {
  id            String   @id @default(cuid())
  name          String                                // Basic / Silver / Gold / Platinum
  tier          MemberTier
  durationDays  Int                                   // 30 / 90 / 180 / 365
  priceNpr      Decimal  @db.Decimal(12,2)
  vatPercent    Decimal  @db.Decimal(5,2) @default(13.00)
  benefits      Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  members       Member[]
}

model Service {
  id          String   @id @default(cuid())
  name        String                                  // Personal Training, Sauna, etc.
  category    String?                                 // gym | spa | class
  priceNpr    Decimal  @db.Decimal(12,2)
  durationMin Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  bookings    Booking[]
  payments    Payment[]
}

// ─────────────────────────────────────────────────────────────
//  BOOKINGS  (Firestore: bookings)
// ─────────────────────────────────────────────────────────────
model Booking {
  id           String        @id @default(cuid())
  memberId     String
  serviceId    String?
  className    String?                                // dynamic class name from setup
  startAt      DateTime                               // default = now()
  endAt        DateTime                               // default = +1h
  status       BookingStatus @default(scheduled)
  trainer      String?
  notes        String?
  amountNpr    Decimal?      @db.Decimal(12,2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    String?

  member       Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  service      Service?      @relation(fields: [serviceId], references: [id])
  payment      Payment?

  @@index([startAt])
  @@index([memberId, startAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
//  PAYMENTS / TRANSACTIONS  (Firestore: payments)
// ─────────────────────────────────────────────────────────────
model Payment {
  id              String         @id @default(cuid())
  invoiceNumber   String         @unique             // e.g. VFC-INV-0001
  memberId        String
  bookingId       String?        @unique
  serviceId       String?
  amountNpr       Decimal        @db.Decimal(12,2)
  vatNpr          Decimal        @db.Decimal(12,2) @default(0)
  discountNpr     Decimal        @db.Decimal(12,2) @default(0)
  totalNpr        Decimal        @db.Decimal(12,2)
  method          PaymentMethod
  paymentType     String?                            // membership | service | walk-in | top-up
  status          PaymentStatus  @default(paid)
  receivedBy      String?                            // appUser id
  externalRef     String?                            // Stripe id, eSewa ref, etc.
  notes           String?
  paidAt          DateTime       @default(now())
  createdAt       DateTime       @default(now())

  member          Member         @relation(fields: [memberId], references: [id])
  booking         Booking?       @relation(fields: [bookingId], references: [id])
  service         Service?       @relation(fields: [serviceId], references: [id])

  @@index([paidAt])
  @@index([method])
  @@index([memberId, paidAt])
}

// ─────────────────────────────────────────────────────────────
//  ATTENDANCE / CHECK-INS  (Firestore: checkIns)
// ─────────────────────────────────────────────────────────────
model CheckIn {
  id        String   @id @default(cuid())
  memberId  String
  checkInAt DateTime @default(now())
  checkOutAt DateTime?
  source    String?                                  // qr | manual | kiosk
  staffId   String?

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([checkInAt])
  @@index([memberId, checkInAt])
}

// ─────────────────────────────────────────────────────────────
//  EMAIL TEMPLATES & REMINDERS
//  (Firestore: emailTemplates, emailReminders)
// ─────────────────────────────────────────────────────────────
model EmailTemplate {
  key       String   @id                              // membership_expiring | booking_reminder | ...
  subject   String
  body      String                                    // plain-text fallback
  html      String?                                   // rendered HTML from Unlayer
  design    Json?                                     // Unlayer design JSON
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model EmailReminder {
  id             String          @id @default(cuid())
  memberId       String?
  recipientEmail String
  recipientName  String?
  templateKey    String
  subject        String
  body           String
  channel        ReminderChannel @default(mailto)
  status         ReminderStatus  @default(sent)
  errorMessage   String?
  sentAt         DateTime        @default(now())
  sentByUserId   String?

  member         Member?         @relation(fields: [memberId], references: [id])
  sentBy         AppUser?        @relation(fields: [sentByUserId], references: [id])

  @@index([sentAt])
  @@index([templateKey])
}

// ─────────────────────────────────────────────────────────────
//  AUDIT LOG  (Firestore: auditLogs)
// ─────────────────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?                                  // appUser.id
  actorEmail String?
  action     String                                   // member.create, booking.delete, ...
  entityType String                                   // member | booking | payment | user | settings
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor      AppUser? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorId])
}

// ─────────────────────────────────────────────────────────────
//  COMPANY SETTINGS  (Firestore: companySettings, single doc "main")
// ─────────────────────────────────────────────────────────────
model CompanySetting {
  id              String   @id @default("main")
  companyName     String
  companyEmail    String?
  companyPhone    String?
  companyAddress  String?
  logoUrl         String?
  vatPercent      Decimal  @db.Decimal(5,2) @default(13.00)
  currency        String   @default("NPR")
  classes         Json?                               // [{name, capacity}]
  serviceTypes    Json?
  paymentModes    Json?
  paymentTypes    Json?
  planDurations   Json?
  resendEndpoint  String?                             // Cloud Function URL
  resendFromEmail String?
  resendFromName  String?
  unlayerProjectId Int?
  updatedAt       DateTime @updatedAt
}
