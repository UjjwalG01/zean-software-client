rules_version = '2';

// VitaFit Club Firestore rules
// Deploy: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/appUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/appUsers/$(request.auth.uid)).data.role == 'admin';
    }

    // Business collections — any signed-in user
    match /members/{id}            { allow read, write: if isSignedIn(); }
    match /bookings/{id}           { allow read, write: if isSignedIn(); }
    match /payments/{id}           { allow read, write: if isSignedIn(); }
    match /transactions/{id}       { allow read, write: if isSignedIn(); }
    match /services/{id}           { allow read, write: if isSignedIn(); }
    match /membershipPlans/{id}    { allow read, write: if isSignedIn(); }

    // companySettings — readable by all signed-in users (incl. discountRules doc).
    // Only admins can mutate.
    match /companySettings/{id}    {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // checkIns — signed-in users can read/write attendance
    match /checkIns/{id}           { allow read, write: if isSignedIn(); }

    // Email templates — readable by all signed-in users; admins manage
    match /emailTemplates/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Email reminder log — readable by all signed-in users; create by anyone signed-in
    match /emailReminders/{id} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // App users — any signed-in user can read the directory; admins manage
    match /appUsers/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // self-signup creates own doc
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Audit logs — readable by all signed-in users; append-only; never mutated
    match /auditLogs/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
