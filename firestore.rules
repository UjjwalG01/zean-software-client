rules_version = '2';

// VitaFit Club Firestore rules
// Authenticated users can read/write business data; appUsers + auditLogs are read-restricted
// to admins through helper checks. Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/appUsers/$(request.auth.uid))
        && get(/databases/$(database)/documents/appUsers/$(request.auth.uid)).data.role == 'admin';
    }

    // Business collections — any signed-in user
    match /members/{id}            { allow read, write: if isSignedIn(); }
    match /bookings/{id}           { allow read, write: if isSignedIn(); }
    match /payments/{id}           { allow read, write: if isSignedIn(); }
    match /transactions/{id}       { allow read, write: if isSignedIn(); }
    match /services/{id}           { allow read, write: if isSignedIn(); }
    match /membershipPlans/{id}    { allow read, write: if isSignedIn(); }
    match /companySettings/{id}    { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /checkIns/{id}           { allow read, write: if isSignedIn(); }
    match /emailTemplates/{id}     { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /emailReminders/{id}     { allow read, write: if isSignedIn(); }

    // App users — self read, admin manage
    match /appUsers/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn(); // self-signup creates own doc
      allow update, delete: if isAdmin();
    }

    // Audit logs — append-only, admin read
    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
